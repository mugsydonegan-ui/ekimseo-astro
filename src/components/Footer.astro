---
const year = new Date().getFullYear();
---

<footer class="bg-[#1a3a2a] text-[#f5f0e8]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_auto] gap-12 py-16 border-b border-white/10">

      <div class="max-w-sm">
        <div class="flex items-center gap-2 mb-5">
          <div class="w-8 h-8 bg-[#c9973a] flex items-center justify-center">
            <span class="text-[#1a3a2a] text-xs font-black tracking-widest">E</span>
          </div>
          <span class="text-lg font-black tracking-tight text-[#f5f0e8]">EkimSEO</span>
        </div>
        <p class="text-[#b8b2a4] text-sm leading-relaxed max-w-[42ch]">
          SEO content for Shopify pet brands. We write articles that rank, drive traffic, and convert browsers into buyers.
        </p>
        <a
          href="mailto:mike@ekimseo.com"
          class="inline-block mt-6 text-sm font-semibold text-[#c9973a] hover:text-[#e0b45a] transition-colors"
        >
          mike@ekimseo.com
        </a>
      </div>

      <div>
        <p class="text-xs font-semibold tracking-widest text-[#8a8678] uppercase mb-4">Services</p>
        <ul class="space-y-3 text-sm">
          <li><a href="/#services" class="text-[#b8b2a4] hover:text-[#f5f0e8] transition-colors">Content Gap Analysis</a></li>
          <li><a href="/#services" class="text-[#b8b2a4] hover:text-[#f5f0e8] transition-colors">AI-Assisted Writing</a></li>
          <li><a href="/#services" class="text-[#b8b2a4] hover:text-[#f5f0e8] transition-colors">Internal Linking</a></li>
          <li><a href="/#services" class="text-[#b8b2a4] hover:text-[#f5f0e8] transition-colors">Meta Optimization</a></li>
        </ul>
      </div>

      <div>
        <p class="text-xs font-semibold tracking-widest text-[#8a8678] uppercase mb-4">Company</p>
        <ul class="space-y-3 text-sm">
          <li><a href="/#pricing" class="text-[#b8b2a4] hover:text-[#f5f0e8] transition-colors">Pricing</a></li>
          <li><a href="/blog" class="text-[#b8b2a4] hover:text-[#f5f0e8] transition-colors">Blog</a></li>
          <li><a href="/#faq" class="text-[#b8b2a4] hover:text-[#f5f0e8] transition-colors">FAQ</a></li>
          <li><a href="mailto:mike@ekimseo.com" class="text-[#b8b2a4] hover:text-[#f5f0e8] transition-colors">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 py-6">
      <p class="text-xs text-[#8a8678]">&copy; {year} EkimSEO. All rights reserved.</p>
      <p class="text-xs text-[#8a8678]">SEO content writing for Shopify pet brands.</p>
    </div>
  </div>
</footer>
