---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'EkimSEO Blog',
  description: 'SEO content strategy for Shopify pet brands. Guides on keyword research, internal linking, meta optimization, and content gap analysis.',
  url: 'https://ekimseo.com/blog',
  publisher: {
    '@type': 'Organization',
    name: 'EkimSEO',
    url: 'https://ekimseo.com',
  },
};
---

<BaseLayout
  title="SEO Content Strategy for Pet Brands | EkimSEO Blog"
  description="Guides on SEO content strategy for Shopify pet brands. Learn keyword research, internal linking, meta optimization, and content gap analysis from EkimSEO."
  structuredData={structuredData}
  tags={['SEO for pet brands', 'Shopify content strategy', 'pet brand blog', 'SEO content writing']}
>

  <!-- Header -->
  <section class="bg-[#1a3a2a] py-20 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="inline-flex items-center gap-2 mb-6">
        <div class="w-6 h-px bg-[#c9973a]"></div>
        <span class="text-xs font-semibold tracking-widest text-[#c9973a] uppercase">EkimSEO Blog</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-black text-[#f5f0e8] tracking-tight leading-none mb-6">
        SEO content guides<br/>for pet brands
      </h1>
      <p class="text-[#b8b2a4] text-lg max-w-[52ch]">
        Practical guides on ranking your Shopify pet store. Keyword research, internal linking, meta optimization, and content strategy — written for founders, not agencies.
      </p>
    </div>
  </section>

  <!-- Posts -->
  <section class="bg-[#f5f0e8] py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      {posts.length === 0 ? (
        <p class="text-[#8a8678]">No posts published yet.</p>
      ) : (
        <div class="divide-y divide-[#1a3a2a]/10">
          {posts.map((post) => (
            <article class="py-10 grid grid-cols-1 md:grid-cols-[1fr_200px] gap-6 items-start group">
              <div>
                <div class="flex flex-wrap gap-2 mb-3">
                  {post.data.tags.slice(0, 2).map((tag: string) => (
                    <span class="text-xs font-semibold tracking-widest text-[#c9973a] uppercase">{tag}</span>
                  ))}
                </div>
                <h2 class="text-xl md:text-2xl font-black text-[#1a3a2a] tracking-tight leading-tight mb-3 group-hover:text-[#c9973a] transition-colors">
                  <a href={`/blog/${post.id}`} class="hover:underline underline-offset-4">
                    {post.data.title}
                  </a>
                </h2>
                <p class="text-[#3d3d38] leading-relaxed max-w-[65ch]">{post.data.description}</p>
                <a
                  href={`/blog/${post.id}`}
                  class="inline-flex items-center gap-2 mt-4 text-sm font-semibold text-[#1a3a2a] hover:text-[#c9973a] transition-colors"
                >
                  Read article
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
                    <path strokeLinecap="round" strokeLinejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
              <div class="text-right">
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-sm text-[#8a8678]"
                >
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <p class="text-xs text-[#b8b2a4] mt-1">{post.data.author}</p>
              </div>
            </article>
          ))}
        </div>
      )}

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#ece5d5] py-16 border-t border-[#1a3a2a]/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-8 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-black text-[#1a3a2a] tracking-tight mb-2">Want us to implement this for your store?</h2>
          <p class="text-[#3d3d38]">EkimSEO handles the keyword research, writing, and publishing. You focus on running your brand.</p>
        </div>
        <a
          href="mailto:mike@ekimseo.com"
          class="inline-flex items-center gap-2 px-7 py-4 text-sm font-semibold text-[#f5f0e8] bg-[#1a3a2a] hover:bg-[#c9973a] active:scale-[0.98] transition-all duration-200 whitespace-nowrap"
        >
          Get a Free Audit
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
            <path strokeLinecap="round" strokeLinejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
