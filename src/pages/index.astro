        <div class="p-8 md:p-10 border-t md:border-t-0 md:border-l border-[#1a3a2a]/15 flex flex-col">
          <div>
            <p class="text-xs font-semibold tracking-widest text-[#8a8678] uppercase mb-4">Authority</p>
            <div class="flex items-baseline gap-1 mb-1">
              <span class="text-5xl font-black text-[#1a3a2a] tracking-tight">$1,497</span>
              <span class="text-[#8a8678] text-sm">/mo</span>
            </div>
            <p class="text-[#3d3d38] text-sm mb-8">10 articles per month</p>
            <div class="space-y-3 mb-10">
              {[
                'Everything in Growth',
                '10 SEO-optimized articles',
                'Full site internal link audit',
                'Schema markup on all pages',
                'Dedicated content strategist',
                'Weekly progress calls',
                'Competitor gap monitoring',
              ].map((feature) => (
                <div class="flex items-center gap-3">
                  <div class="w-4 h-4 border border-[#1a3a2a]/30 flex items-center justify-center shrink-0">
                    <div class="w-1.5 h-1.5 bg-[#1a3a2a]"></div>
                  </div>
                  <span class="text-sm text-[#3d3d38]">{feature}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="mt-auto">
            <p class="text-xs text-[#8a8678] mb-4">Good for: High-growth pet brands competing for category leadership.</p>
            <a
