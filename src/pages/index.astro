          <p class="text-[#3d3d38] leading-relaxed">
            Still have questions? <a href="mailto:mike@ekimseo.com" class="text-[#1a3a2a] font-semibold underline underline-offset-2 hover:text-[#c9973a] transition-colors">Email mike directly.</a>
          </p>
        </div>
        <div>
          <FAQ client:visible items={faqItems} />
        </div>
      </div>
    </div>
  </section>

