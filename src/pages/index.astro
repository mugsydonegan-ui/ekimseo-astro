---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'EkimSEO',
  description: 'SEO content writing service for Shopify pet brands. We write blog articles that rank on Google and drive organic traffic.',
  url: 'https://ekimseo.com',
  email: 'mike@ekimseo.com',
  serviceType: 'SEO Content Writing',
  areaServed: 'Worldwide',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'SEO Content Plans',
    itemListElement: [
      {
        '@type': 'Offer',
        name: 'Starter Plan',
        price: '497',
        priceCurrency: 'USD',
        description: '3 SEO-optimized blog articles per month',
      },
      {
        '@type': 'Offer',
        name: 'Growth Plan',
        price: '797',
        priceCurrency: 'USD',
        description: '5 SEO-optimized blog articles per month',
      },
      {
        '@type': 'Offer',
        name: 'Authority Plan',
        price: '1497',
        priceCurrency: 'USD',
        description: '10 SEO-optimized blog articles per month',
      },
    ],
  },
};

const faqItems = [
  {
    question: 'Do you only work with pet brands?',
    answer: 'Yes. We exclusively work with Shopify pet brands — dog, cat, small animal, reptile, and equine. That focus means we know the search landscape, the seasonal trends, and the buyer psychology inside out. You get a writer who understands your niche, not a generalist guessing their way through.',
  },
  {
    question: 'How does the AI-assisted writing process work?',
    answer: 'We use AI tools to accelerate research, structure outlines, and identify keyword gaps — then human editors refine and rewrite every article to match your brand voice. You get the output speed of AI with the quality and judgment of an experienced content strategist. Every article is original and passes plagiarism checks.',
  },
  {
    question: 'How long until I see results in Google?',
    answer: 'Most clients see measurable movement within 60–90 days of publishing their first batch of articles. SEO is cumulative: results build month over month as your content clusters expand, internal links strengthen, and Google builds trust in your domain. Clients on the Authority plan typically see the most dramatic improvements at the 4–6 month mark.',
  },
  {
    question: 'Can you write for my specific Shopify store theme and product catalog?',
    answer: 'Yes. Before we write a single word, we audit your existing Shopify blog, product catalog, and internal linking structure. Every article is written to fit naturally within your store — linking to relevant products, collections, and existing blog posts to drive both traffic and conversions.',
  },
  {
    question: 'What does the content gap analysis include?',
    answer: 'We analyze the keywords your competitors rank for that you do not, identify low-competition search terms with commercial intent, map topics to your product catalog, and produce a prioritized content calendar. You get a concrete roadmap showing exactly which articles to publish and in what order to close the gap fastest.',
  },
  {
    question: 'Can I approve articles before they go live?',
    answer: 'Every article goes through two rounds of review. You receive a draft in a Google Doc with comments explaining the SEO decisions. You approve, request edits, or pass it back for revisions. We do not publish without your sign-off.',
  },
  {
    question: 'Do you handle publishing to Shopify?',
    answer: 'Yes, if you grant us access. We format the article within Shopify Blog, set the meta title and description, add the featured image with optimized alt text, configure the URL slug, and schedule the publish date. Or we can deliver the fully formatted article for your team to publish — your preference.',
  },
];

const services = [
  {
    number: '01',
    title: 'Content Gap Analysis',
    description: 'We identify every keyword your competitors rank for that your brand does not. You get a prioritized content calendar showing exactly what to publish and when — no guesswork, no wasted effort.',
    detail: 'Competitor research · Keyword mapping · Content calendar · Priority scoring',
  },
  {
    number: '02',
    title: 'AI-Assisted Article Writing',
    description: 'Human strategy, AI efficiency. We produce research-backed, brand-aligned blog articles at a pace your team cannot match in-house. Every article targets a specific search query with clear commercial intent.',
    detail: 'Keyword-targeted · Brand voice matched · Shopify product integration · Original content',
  },
  {
    number: '03',
    title: 'Internal Linking Architecture',
    description: 'Orphaned content does not rank. We build a deliberate internal linking structure that passes authority from high-traffic pages to your product collections and category pages, turning readers into buyers.',
    detail: 'Link mapping · Anchor text strategy · Product page linking · Crawlability audit',
  },
  {
    number: '04',
    title: 'Meta Optimization',
    description: 'Title tags and meta descriptions are the first thing Google and your customers read. We write these for maximum click-through rate — not generic templates, but tested copy that drives impressions into visits.',
    detail: 'Title tag writing · Meta descriptions · OG tags · Featured snippet targeting',
  },
];
---

<BaseLayout
  title="SEO Blog Writing for Shopify Pet Brands | EkimSEO"
  description="EkimSEO writes SEO-optimized blog articles for Shopify pet brands. Content gap analysis, AI-assisted writing, internal linking, and meta optimization. Starter plans from $497/mo."
  structuredData={structuredData}
  tags={['SEO content writing', 'Shopify pet brands', 'pet brand SEO', 'blog articles for pet stores', 'SEO for pet brands']}
>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden bg-[#1a3a2a] min-h-[100dvh] flex items-center">

    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute -right-32 top-0 w-[600px] h-[600px] border border-white/5 rotate-12 translate-y-[-30%]"></div>
      <div class="absolute -right-16 top-20 w-[400px] h-[400px] border border-[#c9973a]/20 rotate-12"></div>
      <div class="absolute right-0 bottom-0 w-[300px] h-[300px] bg-[#c9973a]/5 translate-y-[20%] translate-x-[20%]"></div>
      <div class="absolute left-1/2 bottom-12 w-px h-32 bg-white/10"></div>
      <div class="absolute top-1/3 right-1/4 w-2 h-2 bg-[#c9973a] opacity-60"></div>
      <div class="absolute top-1/2 right-1/3 w-1 h-1 bg-white opacity-30"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-16 items-center">

        <div>
          <div class="inline-flex items-center gap-2 mb-8">
            <div class="w-6 h-px bg-[#c9973a]"></div>
            <span class="text-xs font-semibold tracking-widest text-[#c9973a] uppercase">SEO Content for Pet Brands</span>
          </div>

          <h1 class="text-5xl md:text-7xl font-black text-[#f5f0e8] tracking-tight leading-none mb-8 text-balance">
            Your competitors<br/>
            <span class="text-[#c9973a]">are ranking.</span><br/>
            You should be too.
          </h1>

          <p class="text-[#b8b2a4] text-lg md:text-xl leading-relaxed max-w-[52ch] mb-10">
            EkimSEO writes SEO-optimized blog content for Shopify pet brands. Not generic articles — targeted content built to rank on page 1 and drive organic traffic to your store.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="mailto:mike@ekimseo.com"
              class="inline-flex items-center justify-center gap-2 px-7 py-4 text-sm font-semibold text-[#1a3a2a] bg-[#c9973a] hover:bg-[#e0b45a] active:scale-[0.98] transition-all duration-200"
            >
              Get a Free Content Audit
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
                <path strokeLinecap="round" strokeLinejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a
              href="#pricing"
              class="inline-flex items-center justify-center px-7 py-4 text-sm font-semibold text-[#f5f0e8] border border-white/20 hover:border-white/40 hover:bg-white/5 active:scale-[0.98] transition-all duration-200"
            >
              See Pricing
            </a>
          </div>
        </div>

        <div class="border border-white/10 bg-white/5 backdrop-blur-sm p-8">
          <p class="text-xs font-semibold tracking-widest text-[#8a8678] uppercase mb-6">What consistent SEO content does</p>
          <div class="space-y-6">
            <div class="border-t border-white/10 pt-6">
              <p class="text-4xl font-black text-[#f5f0e8] tracking-tight">+312%</p>
              <p class="text-sm text-[#8a8678] mt-1">Average organic traffic growth in 6 months for clients on the Authority plan</p>
            </div>
            <div class="border-t border-white/10 pt-6">
              <p class="text-4xl font-black text-[#f5f0e8] tracking-tight">47.2%</p>
              <p class="text-sm text-[#8a8678] mt-1">Avg. increase in non-branded search impressions within 90 days</p>
            </div>
            <div class="border-t border-white/10 pt-6">
              <p class="text-4xl font-black text-[#c9973a] tracking-tight">Page 1</p>
              <p class="text-sm text-[#8a8678] mt-1">Average ranking position for primary target keywords after 4 months</p>
            </div>
          </div>
        </div>

      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#c9973a]/40 to-transparent"></div>
  </section>

  <!-- ===== PROBLEM / PAIN ===== -->
  <section class="bg-[#f5f0e8] py-24 md:py-32 border-b border-[#1a3a2a]/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-16 items-start">
        <div>
          <div class="inline-flex items-center gap-2 mb-6">
            <div class="w-6 h-px bg-[#c9973a]"></div>
            <span class="text-xs font-semibold tracking-widest text-[#c9973a] uppercase">The Problem</span>
          </div>
          <h2 class="text-4xl md:text-5xl font-black text-[#1a3a2a] tracking-tight leading-tight text-balance">
            Most pet brands lose organic traffic before they ever start
          </h2>
        </div>
        <div class="space-y-8">
          <p class="text-[#3d3d38] text-lg leading-relaxed">
            You have great products. You have a real brand. But when a dog owner searches "best grain-free dog food for sensitive stomachs" or "how to train a rescue puppy," it is your competitor's blog — not yours — that shows up. That is a buyer you will never see.
          </p>
          <div class="space-y-5">
            {[
              'Your blog exists but has not been updated in 4 months.',
              'You wrote a few articles but none of them target what people actually search.',
              'Your Shopify product pages rank, but there is no content pulling in top-of-funnel traffic.',
              "You've tried hiring freelancers — the articles read fine but do nothing for your rankings.",
            ].map((pain) => (
              <div class="flex items-start gap-4">
                <div class="mt-1 w-5 h-5 shrink-0 border border-[#c9973a]/40 flex items-center justify-center">
                  <div class="w-2 h-2 bg-[#c9973a]"></div>
                </div>
                <p class="text-[#3d3d38] leading-relaxed">{pain}</p>
              </div>
            ))}
          </div>
          <div class="border-l-2 border-[#c9973a] pl-6 py-1">
            <p class="text-[#1a3a2a] font-semibold leading-relaxed">
              The gap between you and the brands ranking on page 1 is not product quality. It is content volume, keyword strategy, and consistency.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section id="services" class="bg-[#1a3a2a] py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <div class="inline-flex items-center gap-2 mb-6">
          <div class="w-6 h-px bg-[#c9973a]"></div>
          <span class="text-xs font-semibold tracking-widest text-[#c9973a] uppercase">What We Do</span>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-8 items-end">
          <h2 class="text-4xl md:text-5xl font-black text-[#f5f0e8] tracking-tight leading-tight text-balance">
            Four services.<br/>One goal: page 1.
