                  <div class="w-4 h-4 border border-[#1a3a2a]/30 flex items-center justify-center shrink-0">
                    <div class="w-1.5 h-1.5 bg-[#1a3a2a]"></div>
                  </div>
                  <span class="text-sm text-[#3d3d38]">{feature}</span>
                </div>
