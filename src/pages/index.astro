        <div class="p-8 md:p-10 bg-[#1a3a2a] flex flex-col relative">
          <div class="absolute top-0 left-8 md:left-10">
            <span class="inline-block bg-[#c9973a] text-[#1a3a2a] text-xs font-black tracking-widest uppercase px-3 py-1 -translate-y-1/2">Most Popular</span>
          </div>
          <div class="mt-4 md:mt-2">
            <p class="text-xs font-semibold tracking-widest text-[#c9973a] uppercase mb-4">Growth</p>
            <div class="flex items-baseline gap-1 mb-1">
              <span class="text-5xl font-black text-[#f5f0e8] tracking-tight">$797</span>
              <span class="text-[#8a8678] text-sm">/mo</span>
            </div>
            <p class="text-[#b8b2a4] text-sm mb-8">5 articles per month</p>
            <div class="space-y-3 mb-10">
              {[
                'Everything in Starter',
                '5 SEO-optimized articles',
                'Topic cluster strategy',
                'Shopify publishing included',
                'Priority turnaround',
                'Quarterly content audit',
              ].map((feature) => (
                <div class="flex items-center gap-3">
                  <div class="w-4 h-4 border border-[#c9973a]/50 flex items-center justify-center shrink-0">
                    <div class="w-1.5 h-1.5 bg-[#c9973a]"></div>
                  </div>
                  <span class="text-sm text-[#b8b2a4]">{feature}</span>
